#!/bin/bash

# --- Step 0: Take credentials as input ---
read -p "Username: " USERNAME
read -s -p "Password: " PASSWORD
echo
PORTAL_URL="https://login.iitmandi.ac.in:1003/portal?"

# --- Step 1: Fetch login page ---
echo "[*] Fetching login page..."
curl -s -k -L "$PORTAL_URL" -o login.html

# --- Step 2: Extract magic and 4Tredir values (if present) ---
MAGIC=$(grep -oP 'name="magic" value="\K[^"]+' login.html)
REDIR=$(grep -oP 'name="4Tredir" value="\K[^"]+' login.html)

if [ -z "$MAGIC" ]; then
    echo "[✗] Failed to extract magic token."
    exit 1
fi

echo "[+] magic: $MAGIC"
echo "[+] 4Tredir: $REDIR"

# --- Step 3: Submit credentials ---
echo "[*] Submitting credentials..."
RESPONSE=$(curl -s -k -i -X POST "$PORTAL_URL" \
  -d "username=$USERNAME" \
  -d "password=$PASSWORD" \
  -d "4Tredir=$REDIR" \
  -d "magic=$MAGIC")

# --- Step 4: Extract redirect URL from JS ---
REDIRECT_URL=$(echo "$RESPONSE" | grep -oP 'window.location="\K[^"]+')

if [ -z "$REDIRECT_URL" ]; then
    echo "[✗] Could not find redirect URL in POST response."
    echo "$RESPONSE" > response.html
    exit 1
fi

echo "[*] Following redirect to complete login..."
FINAL_RESPONSE=$(curl -s -k -i "$REDIRECT_URL")

# --- Step 5: Check for success ---
if echo "$FINAL_RESPONSE" | grep -q "Authentication Successful\|logout"; then
    echo "[✓] Login successful ✅"
else
    echo "[✗] Login may have failed. Check above output."
fi
